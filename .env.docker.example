# Port that caddy listens on in internal network.
PORT=3000

# Public client config. Rebuild the app image when VITE_* values change.
VITE_BASE_URL=http://localhost:3000
VITE_CONTACT_MAIL=

# Optional PostHog. Leave blank to disable analytics entirely.
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=
VITE_PUBLIC_POSTHOG_UI_HOST=

# Database and files. Mount /app/instance and /app/storage/images persistently.
DATABASE_URL=./instance/site.db
UPLOADS_DIR_NAME=images
BASE_UPLOADS_LOCATION=/app/storage/images

# Logging. Logs are JSON on stdout; Docker collects them with `docker compose logs`.
# ADMIN_LOG_DIR is only used by the admin Runtime Logs page to read existing log files.
LOG_LEVEL=info
ADMIN_LOG_PREFIX=mylists-
ADMIN_LOG_MAX_BYTES=10485760 # 10MB
# ADMIN_LOG_DIR defaults to ~/.pm2/logs; set it only if log files are mounted in the container.

# Required security settings
ADMIN_PASSWORD=change-me-at-least-8-chars
ADMIN_TOKEN_SECRET=change-me-at-least-20-characters
BETTER_AUTH_SECRET=change-me-at-least-20-characters

# Admin privilege cookie lifetime (optional)
ADMIN_TTL_COOKIE_MIN=10

# Email delivery (optional; both values are required to enable it)
ADMIN_MAIL_USERNAME=
ADMIN_MAIL_PASSWORD=

# Redis Setup. Docker Compose provides a redis service at redis://redis:6379.
CACHE_TTL_MIN=5
REDIS_ENABLED=true
REDIS_URL=redis://redis:6379

# OAuth2 providers (optional; configure either complete pair independently)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# External media providers (optional)
THEMOVIEDB_API_KEY=
GOOGLE_BOOKS_API_KEY=
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# LLM book genre enrichment (optional)
LLM_API_KEY=
# LLM_MODEL_ID=google/gemini-2.5-flash-lite
# LLM_BASE_URL=https://openrouter.ai/api/v1
