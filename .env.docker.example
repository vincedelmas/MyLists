# Port that caddy listens on in internal network.
PORT=3000

# Public client config. Rebuild the app image when VITE_* values change.
VITE_BASE_URL=http://localhost:3000
VITE_CONTACT_MAIL=

# Optional PostHog. Leave blank to disable analytics entirely.
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=
VITE_PUBLIC_POSTHOG_UI_HOST=

# Database and files. Mount /app/instance and /app/storage/images persistently.
DATABASE_URL=./instance/site.db
UPLOADS_DIR_NAME=images
BASE_UPLOADS_LOCATION=/app/storage/images

# Admin Data
ADMIN_PASSWORD=change-me-at-least-8-chars
ADMIN_TTL_COOKIE_MIN=10
ADMIN_MAIL_PASSWORD=change-me-at-least-8-chars
ADMIN_MAIL_USERNAME=change@me.com
ADMIN_TOKEN_SECRET=change-me-at-least-20-characters

# Demo Profile Password
DEMO_PASSWORD=change-me-at-least-8-chars

# Redis Setup. Docker Compose provides a redis service at redis://redis:6379.
CACHE_TTL_MIN=5
REDIS_ENABLED=true
REDIS_URL=redis://redis:6379

# Import drain worker
# Docker does not run systemd, so leave auto-start disabled unless you provide your own process supervisor.
IMPORT_DRAIN_AUTO_START=false
IMPORT_DRAIN_SYSTEMD_USER=false
IMPORT_DRAIN_SYSTEMD_SERVICE=mylists-import-drain.service

# Better Auth Secret
BETTER_AUTH_SECRET=change-me-at-least-20-characters

# OAuth2 Providers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ApiKeys
THEMOVIEDB_API_KEY=
GOOGLE_BOOKS_API_KEY=
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# LLM ROUTER INFO
LLM_MODEL_ID=google/gemini-2.5-flash-lite
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
