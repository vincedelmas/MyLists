# Configuration
DATABASE_URL=./instance/site.db
VITE_BASE_URL=http://localhost:3000
VITE_CONTACT_MAIL=

# Image/Covers Management
UPLOADS_DIR_NAME=static
BASE_UPLOADS_LOCATION=./public/static/

# Posthog - optional
# VITE_PUBLIC_POSTHOG_HOST=
# VITE_PUBLIC_POSTHOG_UI_HOST=
# VITE_PUBLIC_POSTHOG_KEY=

# Logging. Logs are JSON on stdout. In dev, read them from the terminal.
# ADMIN_LOG_DIR is only used by the admin Runtime Logs page to read existing log files in production.
# LOG_LEVEL=info
# ADMIN_LOG_PREFIX=mylists-
# ADMIN_LOG_MAX_BYTES=10485760 # 10MB
# ADMIN_LOG_DIR= # defaults to ~/.pm2/logs; set it if your process manager writes logs elsewhere.

# Required security settings
ADMIN_PASSWORD=
ADMIN_TOKEN_SECRET=
BETTER_AUTH_SECRET=

# Admin privilege cookie lifetime
# ADMIN_TTL_COOKIE_MIN=10

# Email delivery (optional; both values are required to enable it)
# Without email delivery, use `bun run cli -- create-user` to create verified accounts.
ADMIN_MAIL_USERNAME=
ADMIN_MAIL_PASSWORD=

# Redis Setup
CACHE_TTL_MIN=5
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

# OAuth2 providers (optional; configure either complete pair independently)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# External media providers (optional)
# TMDB enables movie, series, and anime search. IGDB enables game search.
# Google Books works without a key, but a key can provide a higher quota.
THEMOVIEDB_API_KEY=
GOOGLE_BOOKS_API_KEY=
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# LLM book genre enrichment (optional)
LLM_API_KEY=
# LLM_MODEL_ID=google/gemini-2.5-flash-lite
# LLM_BASE_URL=https://openrouter.ai/api/v1
