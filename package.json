{
    "name": "mylists",
    "private": true,
    "type": "module",
    "browserslist": [
        ">0.3%, defaults, supports es6-module"
    ],
    "scripts": {
        "lint": "oxlint",
        "knip": "knip-bun",
        "dk": "drizzle-kit",
        "ui": "bunx shadcn@latest",
        "test": "bun run --bun vitest run",
        "preview": "bun --bun vite preview",
        "test:watch": "bun run --bun vitest",
        "build:server": "bun --bun vite build",
        "cli:docker": "bun ./dist/cli/index.js",
        "dev": "bun --bun vite dev --port 3000",
        "cli": "bun --env-file=.env src/cli/index.ts",
        "seed:achievements": "bun run cli -- seed-achievements",
        "email": "email dev -d src/lib/client/components/emails",
        "build:cli": "bun --bun vite build --config vite.cli.config.ts",
        "build": "bun run build:server && bun run build:cli && bun run build:entry",
        "build:entry": "bun build ./server.ts --target=bun --outfile=./dist/server.js",
        "new:db": "mkdir -p instance && bun run dk push --force && bun run seed:achievements",
        "new:db:docker": "mkdir -p instance && bun run dk push --force && bun run cli:docker -- seed-achievements",
        "auth:generate": "bunx @better-auth/cli@latest generate --y --output src/lib/server/database/schema/auth.schema.ts"
    },
    "dependencies": {
        "@hookform/resolvers": "^5.4.0",
        "@radix-ui/react-avatar": "^1.2.3",
        "@radix-ui/react-checkbox": "^1.3.8",
        "@radix-ui/react-dialog": "^1.1.20",
        "@radix-ui/react-dropdown-menu": "^2.1.21",
        "@radix-ui/react-label": "^2.1.12",
        "@radix-ui/react-popover": "^1.1.20",
        "@radix-ui/react-progress": "^1.1.13",
        "@radix-ui/react-select": "^2.3.4",
        "@radix-ui/react-separator": "^1.1.12",
        "@radix-ui/react-slot": "^1.3.0",
        "@radix-ui/react-switch": "^1.3.4",
        "@radix-ui/react-tooltip": "^1.2.13",
        "@react-email/components": "1.0.12",
        "@react-email/render": "^2.1.0",
        "@t3-oss/env-core": "^0.13.11",
        "@tanstack/react-query": "^5.101.3",
        "@tanstack/react-router": "^1.170.18",
        "@tanstack/react-start": "^1.168.32",
        "@tanstack/react-store": "^0.11.0",
        "@tanstack/react-table": "^8.21.3",
        "@tanstack/react-virtual": "^3.14.7",
        "@tanstack/router-ssr-query-core": "^1.169.1",
        "bcrypt": "^6.0.0",
        "better-auth": "1.6.23",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "commander": "^15.0.0",
        "csv-parse": "^7.0.1",
        "dedent": "^1.7.2",
        "drizzle-orm": "^0.45.2",
        "drizzle-zod": "^0.8.3",
        "ioredis": "^5.11.1",
        "lucide-react": "^1.25.0",
        "nodemailer": "^9.0.3",
        "nprogress": "^0.2.0",
        "pino": "^10.3.1",
        "posthog-js": "^1.405.1",
        "radix-ui": "^1.6.4",
        "rate-limiter-flexible": "^11.2.0",
        "react": "19.2.7",
        "react-day-picker": "^10.0.1",
        "react-dom": "19.2.7",
        "react-easy-crop": "^6.2.2",
        "react-email": "6.9.0",
        "react-hook-form": "^7.82.0",
        "react-icons": "^5.7.0",
        "recharts": "^3.10.0",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.6.0",
        "tw-animate-css": "^1.4.0",
        "vaul": "^1.1.2",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@babel/core": "^8.0.1",
        "@libsql/client": "^0.17.4",
        "@react-email/ui": "6.9.0",
        "@rolldown/plugin-babel": "^0.2.3",
        "@tailwindcss/vite": "^4.3.3",
        "@tanstack/react-query-devtools": "^5.101.3",
        "@types/babel__core": "^7.20.5",
        "@types/bcrypt": "^6.0.0",
        "@types/node": "^26.1.1",
        "@types/bun": "^1.3.14",
        "@types/nodemailer": "^8.0.1",
        "@types/nprogress": "^0.2.3",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.3",
        "babel-plugin-react-compiler": "^1.0.0",
        "drizzle-kit": "^0.31.10",
        "knip": "^6.27.0",
        "oxlint": "^1.74.0",
        "oxlint-tsgolint": "^0.25.0",
        "pino-pretty": "^13.1.3",
        "tailwindcss": "^4.3.3",
        "typescript": "^7.0.2",
        "vite": "^8.1.5",
        "vite-plugin-react-click-to-component": "^4.2.2",
        "vitest": "^4.1.10"
    }
}
